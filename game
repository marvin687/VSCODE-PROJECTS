import random

def play_game():
    low = 1
    high = 100
    
    while True:
        target_number = random.randint(low, high)
        attempts_allowed = 7
        attempts_used = 0
        won = False

        print(f"\n--- New Round: Guess a number between {low} and {high} ---")
        print(f"You have {attempts_allowed} attempts.")

        while attempts_used < attempts_allowed:
            user_input = input(f"Attempt {attempts_used + 1}: Enter your guess: ")

            # Handle invalid input (Non-integers)
            try:
                guess = int(user_input)
            except ValueError:
                print("Invalid input! Please enter a whole number. (This didn't cost an attempt)")
                continue

            attempts_used += 1

            if guess < target_number:
                print("Too low")
            elif guess > target_number:
                print("Too high")
            else:
                print(f"Correct! Congratulations, you guessed it in {attempts_used} attempts!")
                won = True
                break
        
        if not won:
            print(f"Game Over. The correct number was {target_number}.")

        # Bonus: Play again and increase difficulty
        play_again = input("\nDo you want to play again? (yes/no): ").lower()
        if play_again == 'yes' or play_again == 'y':
            # Increase difficulty by expanding the range
            high += 50 
            continue
        else:
            print("Thanks for playing!")
            break

if __name__ == "__main__":
    play_game()
